{
  "name": "doc-survival-kit",
  "version": "6.2.0",
  "description": "Dashboard personnel offline : diagrammes, tâches, notes et liens dans un seul fichier HTML — fonctionne sans serveur via file://",
  "bin": {
    "doc-survival-kit": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "i18n/",
    "images/",
    "diagram/",
    "admin.html",
    "diagram.html",
    "diagrammes.js",
    "index.html",
    "liens.js",
    "mesLiens.js",
    "mesNotes.js",
    "notes.js",
    "style.css",
    "taches.js"
  ],
  "engines": {
    "node": ">=16.7.0"
  },
  "keywords": [
    "dashboard",
    "offline",
    "notes",
    "taches",
    "liens",
    "productivity",
    "file-based"
  ],
  "author": "ymedaghri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ymedaghri/doc-survival-kit.git"
  }
}
